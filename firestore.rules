rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Core auth helpers ────────────────────────────────────────────────────────
    // A user's profile lives in executives/, students/, or (legacy) users/.
    // get()/exists() on the same path are memoised within one rule evaluation,
    // so the multi-collection lookup stays well within the access-call budget.
    function signedIn()  { return request.auth != null; }
    function myUid()     { return request.auth.uid; }
    function execSelf()    { return /databases/$(database)/documents/executives/$(myUid()); }
    function studentSelf() { return /databases/$(database)/documents/students/$(myUid()); }
    function legacySelf()  { return /databases/$(database)/documents/users/$(myUid()); }
    function hasProfile()  { return exists(execSelf()) || exists(studentSelf()) || exists(legacySelf()); }
    function selfPath()    { return exists(execSelf()) ? execSelf()
                                  : (exists(studentSelf()) ? studentSelf() : legacySelf()); }
    function myProfile()   { return get(selfPath()).data; }
    function myRole()      { return hasProfile() ? myProfile().role : 'student'; }
    function myActive()    { return hasProfile() && myProfile().active != false; }

    function isAdmin()   { return signedIn() && myRole() == 'admin'; }
    function isExec()    { return signedIn() && myActive() && myRole() in ['admin','executive']; }
    function isTreasurer() {
      return isExec() && 'position' in myProfile()
             && myProfile().position == 'Treasurer';
    }
    function isChairOrVice() {
      return isExec() && 'position' in myProfile()
             && myProfile().position in ['Chairperson','Vice Chairperson'];
    }
    function isInfoPublicity() {
      return isExec() && 'position' in myProfile()
             && myProfile().position == 'Information and Publicity Secretary';
    }
    function isCultural() {
      return isExec() && 'position' in myProfile()
             && myProfile().position == 'Social and Cultural Secretary';
    }
    function isContentEditor()    { return isAdmin() || isInfoPublicity(); }
    function isActivitiesEditor() { return isAdmin() || isInfoPublicity() || isCultural(); }
    function isLibrarian() {
      return isExec() && 'position' in myProfile()
             && myProfile().position in ['Secretary General','Vice Secretary General'];
    }
    function canModLib() { return isAdmin() || isLibrarian(); }

    // ── Field-change guards ──────────────────────────────────────────────────────
    // Fields that ONLY admin may write on a user doc — no self-promotion possible
    function sensitiveUserFields() {
      return ['role','position','active','email','createdAt','createdBy'];
    }
    function notTouchingSensitive() {
      return !request.resource.data.diff(resource.data)
               .affectedKeys().hasAny(sensitiveUserFields());
    }

    // Core payment fields that executives must never alter after submission
    function paymentCoreFields() {
      return ['studentUid','studentEmail','studentName','compNumber',
              'amount','amountInWords','category','method','txRef',
              'proofUrl','submittedAt','notes'];
    }
    function notTouchingPaymentCore() {
      return !request.resource.data.diff(resource.data)
               .affectedKeys().hasAny(paymentCoreFields());
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  USER PROFILES
    //  Own-profile read is always allowed (even when disabled) so guard.js can
    //  detect the disable and force an immediate logout.
    // ════════════════════════════════════════════════════════════════════════════
    // Students live in their own collection. Admin creates any; a signed-in user
    // may self-register only as a student with the required fields (role locked).
    match /students/{uid} {
      allow read: if signedIn() && (myUid() == uid || isExec());
      allow create: if isAdmin()
                    || (signedIn()
                        && myUid() == uid
                        && request.resource.data.role      == 'student'
                        && request.resource.data.active    == true
                        && request.resource.data.name      is string
                        && request.resource.data.name.size()       >= 1
                        && request.resource.data.name.size()       <= 100
                        && request.resource.data.email     is string
                        && request.resource.data.email.size()      >  0
                        && request.resource.data.compNumber is string
                        && request.resource.data.compNumber.size() >  0
                        && request.resource.data.gender    is string
                        && request.resource.data.yearOfStudy is string
                        && request.resource.data.department  is string
                        && request.resource.data.keys().hasAll([
                             'role','name','email','compNumber',
                             'gender','yearOfStudy','department','active','createdAt'
                           ]));
      allow update: if isAdmin()
                    || (signedIn() && myUid() == uid && myActive() && notTouchingSensitive());
      allow delete: if isAdmin();
    }

    // Executives + the Patron (role 'admin') live here. Admin-created only.
    match /executives/{uid} {
      allow read: if signedIn() && (myUid() == uid || isExec());
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (signedIn() && myUid() == uid && myActive() && notTouchingSensitive());
      allow delete: if isAdmin();
    }

    // Legacy collection — accounts created before the split keep working here until
    // the admin runs the migration. Own-profile read stays allowed so guard.js can
    // detect a disable and force logout.
    match /users/{uid} {
      allow read: if signedIn() && (myUid() == uid || isExec());
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (signedIn() && myUid() == uid && myActive() && notTouchingSensitive());
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  PAYMENTS
    // ════════════════════════════════════════════════════════════════════════════
    match /payments/{id} {
      allow read: if signedIn() && myActive()
                  && (resource.data.studentUid == myUid() || isExec());

      // Students submit — all fields strictly validated server-side
      allow create: if signedIn() && myActive()
                    && myRole()                        == 'student'
                    && request.resource.data.studentUid == myUid()
                    && request.resource.data.status     == 'pending'
                    && request.resource.data.amount     is number
                    && request.resource.data.amount     >  0
                    && request.resource.data.amount     <  100000
                    && request.resource.data.category   is string
                    && request.resource.data.category.size() > 0
                    && request.resource.data.proofUrl   is string
                    && request.resource.data.proofUrl.size() > 0
                    && request.resource.data.method     is string
                    && request.resource.data.method.size() > 0;

      // Execs review — locked out of all core submission fields
      allow update: if isExec() && notTouchingPaymentCore();

      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  INFRASTRUCTURE
    // ════════════════════════════════════════════════════════════════════════════
    match /counters/{id} {
      allow read:  if signedIn() && myActive();
      allow write: if isExec();
    }

    // Settings hold sensitive configuration — access is role-gated per document.
    // settings/adminApi contains the admin-delete secret — admin-only read, never exec.
    // All other settings docs (emailRelay, etc.) are exec-readable for operational use.
    match /settings/{id} {
      // adminApi holds the delete secret — admin only.
      // emailRelay holds the Apps Script webhook URL + token — students need it
      // to trigger their own placement letter after accepting.
      // All other settings are exec-only.
      allow read:  if id == 'adminApi'    ? isAdmin()
                 : id == 'emailRelay'    ? (signedIn() && myActive())
                 : isExec();
      allow write: if isAdmin();
    }

    match /auditLog/{id} {
      allow read:   if isExec();
      // Append-only: users create their own entries; no one may update or delete
      // (preserves audit trail integrity — tamper evident).
      allow create: if signedIn() && myActive()
                    && request.resource.data.uid    == myUid()
                    && request.resource.data.action is string
                    && request.resource.data.action.size() > 0
                    && request.resource.data.action.size() < 200
                    && request.resource.data.keys().hasAll(['action','uid','at']);
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  COMP# → EMAIL INDEX
    //  Public read is intentional: login resolves comp# → email before auth exists.
    //  Writes are locked to the user's own uid in the payload.
    // ════════════════════════════════════════════════════════════════════════════
    // ════════════════════════════════════════════════════════════════════════════
    //  PUBLIC SITE — public-read collections (published == true), role-gated writes
    // ════════════════════════════════════════════════════════════════════════════

    // Executive public profiles (separate from /users — no sensitive data here)
    match /execProfiles/{id} {
      allow read:  if resource.data.published == true || isContentEditor();
      allow create: if isContentEditor()
                   && request.resource.data.name     is string
                   && request.resource.data.name.size() >= 1
                   && request.resource.data.name.size() <= 120
                   && request.resource.data.position is string
                   && request.resource.data.position.size() > 0
                   && request.resource.data.tier     is number
                   && request.resource.data.rank     is number;
      allow update: if isContentEditor();
      allow delete: if isContentEditor();
    }

    // FAQ items
    match /faq/{id} {
      allow read:  if resource.data.published == true || isContentEditor();
      allow create: if isContentEditor()
                   && request.resource.data.question is string
                   && request.resource.data.question.size() >= 1
                   && request.resource.data.question.size() <= 500
                   && request.resource.data.answer   is string
                   && request.resource.data.answer.size()   > 0;
      allow update: if isContentEditor();
      allow delete: if isContentEditor();
    }

    // Singleton site content docs (about, home, contact)
    match /siteContent/{id} {
      allow read:  if true;
      allow write: if isContentEditor();
    }

    // Activities — writable by Info & Publicity OR Social & Cultural
    match /activities/{id} {
      allow read:  if resource.data.published == true || isActivitiesEditor();
      allow create: if isActivitiesEditor()
                   && request.resource.data.title    is string
                   && request.resource.data.title.size() >= 1
                   && request.resource.data.title.size() <= 200
                   && request.resource.data.category is string
                   && request.resource.data.category.size() > 0;
      allow update: if isActivitiesEditor();
      allow delete: if isActivitiesEditor();
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  LIBRARY
    // ════════════════════════════════════════════════════════════════════════════

    // Course catalogue — seeded by admin, read by any signed-in user
    match /libraryCourses/{id} {
      allow read:  if signedIn() && myActive();
      allow write: if isAdmin();
    }

    // Library files — members upload; librarians/admin moderate; members read approved
    match /libraryFiles/{id} {
      allow read: if signedIn() && myActive();

      allow create: if signedIn() && myActive()
                    && request.resource.data.uploadedBy == myUid()
                    && request.resource.data.originalName is string
                    && request.resource.data.originalName.size() > 0
                    && request.resource.data.originalName.size() <= 255
                    && request.resource.data.courseName  is string
                    && request.resource.data.courseName.size()   <= 100
                    && request.resource.data.subfolder   is string
                    && request.resource.data.subfolder.size()    <= 100
                    && request.resource.data.ratingCount == 0
                    && request.resource.data.avgRating   == 0
                    && request.resource.data.reportCount == 0
                    && request.resource.data.isFlagged   == false;

      // Librarians and admins can approve/reject/restore; members can flag and rate
      allow update: if canModLib()
                    || (signedIn() && myActive()
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['isFlagged','reportCount','avgRating','ratingCount']));

      allow delete: if canModLib();
    }

    // Library reports — members file; librarians/admin read and resolve
    match /libraryReports/{id} {
      allow read:   if canModLib();
      allow create: if signedIn() && myActive()
                    && request.resource.data.reportedBy == myUid()
                    && request.resource.data.reason     is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.resolved   == false;
      allow update: if canModLib();
      allow delete: if isAdmin();
    }

    // Library ratings — each member rates once per file (doc ID = fileId_uid)
    match /libraryRatings/{id} {
      allow read:   if signedIn() && myActive();
      allow create: if signedIn() && myActive()
                    && request.resource.data.uid    == myUid()
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;
      allow update: if signedIn() && myActive() && resource.data.uid == myUid()
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5;
      allow delete: if isAdmin();
    }

    match /compIndex/{id} {
      allow read:  if true;
      allow write: if isAdmin()
                   || (signedIn() && myActive()
                       && request.resource.data.uid   == myUid()
                       && request.resource.data.email is string
                       && request.resource.data.email.size() > 0
                       && request.resource.data.keys().hasAll(['email','uid']));
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  FINANCES
    // ════════════════════════════════════════════════════════════════════════════
    match /otherIncome/{id} {
      allow read: if isExec();

      allow create: if (isTreasurer() || isAdmin())
                    && request.resource.data.amount   is number
                    && request.resource.data.amount   >  0
                    && request.resource.data.source   is string
                    && request.resource.data.source.size() > 0
                    && request.resource.data.addedBy  == myUid();

      allow update: if isTreasurer() || isAdmin();
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  INDUSTRIAL ATTACHMENT
    // ════════════════════════════════════════════════════════════════════════════

    // Secretary = executive with position "Industrial Training Secretary"
    function isSecretary() {
      return isExec() && 'position' in myProfile()
             && myProfile().position == 'Industrial Training Secretary';
    }
    function canManageAttachment() { return isAdmin() || isSecretary(); }

    // Settings + template + placeholders — secretary or admin edits; paid students read session status
    match /attachmentSettings/{id} {
      allow read:  if signedIn() && myActive();
      allow write: if canManageAttachment();
    }
    match /attachmentTemplate/{id} {
      allow read:  if signedIn() && myActive();
      allow write: if canManageAttachment();
    }
    match /attachmentPlaceholders/{id} {
      allow read:  if signedIn() && myActive();
      allow write: if canManageAttachment();
    }

    // Student requests — students create their own; secretary/admin reads + updates status
    match /attachmentRequests/{id} {
      allow read:  if canManageAttachment()
                   || (signedIn() && myActive() && resource.data.studentUid == myUid());
      allow create: if signedIn() && myActive()
                    && myRole() == 'student'
                    && request.resource.data.studentUid == myUid()
                    && request.resource.data.status     == 'pending'
                    && request.resource.data.studentName is string
                    && request.resource.data.studentEmail is string;
      allow update: if canManageAttachment();
      allow delete: if canManageAttachment();
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  PLACEMENT MATCHING
    // ════════════════════════════════════════════════════════════════════════════

    // Placement state machine: each student gets ONE placement doc (placements/{uid})
    // Status: pending → matched → confirmed, or pending → rejected/expired → pending
    function isSG() {
      return isExec() && 'position' in myProfile()
             && myProfile().position == 'Secretary General';
    }

    match /placements/{uid} {
      // Students read/write own placement doc while in pending state
      allow read: if signedIn() && (myUid() == uid || isSecretary() || isSG());
      allow create: if signedIn() && myActive()
                    && myUid() == uid
                    && myRole() == 'student'
                    && request.resource.data.placementStatus == 'pending'
                    && request.resource.data.cvUrl is string
                    && request.resource.data.cvUrl.size() > 0
                    && request.resource.data.preferredProvinces is list
                    && request.resource.data.preferredProvinces.size() >= 1
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() > 0
                    && request.resource.data.rejectionCount == 0;
      // Students can edit their own pending doc (province, phone, CV)
      allow update: if signedIn() && myActive()
                    && myUid() == uid
                    && resource.data.placementStatus == 'pending'
                    && request.resource.data.placementStatus == 'pending'
                    && !request.resource.data.diff(resource.data)
                         .affectedKeys().hasAny(['matchedCompanyId','matchedAt','rejectionCount']);
      // Students can respond to a match:
      //   auto mode  → confirmed (letter sent client-side)
      //   manual mode → awaiting_ts_approval (TS reviews before confirming)
      //   reject     → pending (with rejectionCount increment and match fields cleared)
      allow update: if signedIn() && myActive()
                    && myUid() == uid
                    && resource.data.placementStatus == 'matched'
                    && request.resource.data.placementStatus in ['confirmed', 'pending', 'awaiting_ts_approval']
                    && !request.resource.data.diff(resource.data)
                         .affectedKeys().hasAny(['preferredProvince','preferredProvinces','phone','createdBy','createdAt']);
      // TS/SG can update any field (matching, expiry resets, etc.)
      allow update: if (isSecretary() || isSG());
      allow delete: if isAdmin();
    }

    // Vacancies: job postings created by TS or SG; students read to display matched company
    match /vacancies/{id} {
      allow read: if signedIn() && myActive();
      allow create: if (isSecretary() || isSG())
                    && request.resource.data.companyName is string
                    && request.resource.data.companyName.size() > 0
                    && request.resource.data.province is string
                    && request.resource.data.district is string
                    && request.resource.data.type in ['Attachment','Internship']
                    && request.resource.data.genderPreference in ['Male','Female','All']
                    && request.resource.data.departmentsRequired is map
                    && request.resource.data.slotsRemaining is map
                    && request.resource.data.createdBy == myUid();
      // TS can update/match; SG can ONLY update vacant slots (no manual override)
      allow update: if isSecretary()
                    || (isSG() && !request.resource.data.diff(resource.data)
                         .affectedKeys().hasAny(['departmentsRequired']));
      allow delete: if isAdmin() || isSecretary() || isSG();
    }

    // Placement archive: moved when fully confirmed
    match /placementArchive/{id} {
      allow read: if isSecretary() || isSG();
      allow write: if isAdmin();
    }

    // Letter templates (Google Doc links for Attachment and Internship)
    match /siteContent/placementLetterTemplates {
      allow read: if signedIn() && myActive();
      allow write: if canManageAttachment();
    }

    // Placement-specific placeholders (like attachment letter placeholders)
    match /placementPlaceholders/{id} {
      allow read: if signedIn() && myActive();
      allow write: if canManageAttachment();
    }

    // ════════════════════════════════════════════════════════════════════════════
    //  RECEIPT VERIFICATIONS
    //  Public read so anyone can verify a receipt without logging in.
    //  Only active executives write — one doc per receipt number.
    // ════════════════════════════════════════════════════════════════════════════
    match /verifications/{receiptNo} {
      allow read:   if true;          // publicly verifiable
      allow create: if isExec()
                    && request.resource.data.tok is string
                    && request.resource.data.tok.size() == 32
                    && request.resource.data.receiptNo is number
                    && request.resource.data.amount    is number;
      allow update: if false;         // immutable after creation
      allow delete: if isAdmin();
    }

    match /expenses/{id} {
      allow read: if isExec();

      allow create: if (isTreasurer() || isAdmin())
                    && request.resource.data.amount      is number
                    && request.resource.data.amount      >  0
                    && request.resource.data.purpose     is string
                    && request.resource.data.purpose.size() > 0
                    && request.resource.data.status      == 'pending'
                    && request.resource.data.requestedBy == myUid();

      // Only Chair / Vice Chair may approve — and never their own request
      allow update: if isAdmin()
                    || (isChairOrVice() && resource.data.requestedBy != myUid());

      allow delete: if isAdmin();
    }

    // Site-wide settings written by admin (e.g. yearUpdate flag for student year edits)
    match /siteSettings/{id} {
      allow read:  if signedIn() && myActive();
      allow write: if isAdmin();
    }
  }
}
